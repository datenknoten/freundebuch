{
  "name": "freundebuch2",
  "version": "2.69.1",
  "private": true,
  "type": "module",
  "license": "AGPL-3.0-only",
  "description": "Freundebuch - A digital friendship book for adults",
  "scripts": {
    "dev": "aube --parallel --stream run dev",
    "build": "aube --filter @freundebuch/shared run build && aube --filter '!@freundebuch/shared' --recursive run build",
    "test": "aube --recursive run test && aube run test:php",
    "test:php": "cd apps/sabredav && ./vendor/bin/phpunit",
    "test:unit": "aube --recursive run test:unit",
    "test:integration": "aube --recursive run test:integration",
    "test:e2e": "aube --recursive run test:e2e",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check --write .",
    "type-check": "aube --filter @freundebuch/shared run build && aube --recursive run type-check",
    "migrate": "aube --filter @freundebuch/backend run migrate",
    "migrate:build": "tsc --project database/tsconfig.json",
    "migrate:prod": "node node_modules/node-pg-migrate/bin/node-pg-migrate.js --decamelize --migrations-dir database/dist up",
    "migrate:create": "aube --filter @freundebuch/backend run migrate:create",
    "pgtyped": "aube --filter @freundebuch/backend run pgtyped",
    "pgtyped:watch": "aube --filter @freundebuch/backend run pgtyped:watch",
    "seed": "aube --filter @freundebuch/backend run seed",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "prepare": "command -v hk >/dev/null && hk install --mise; aube --filter @freundebuch/frontend run sync --no-install",
    "release": "semantic-release",
    "version:sync": "node scripts/sync-versions.mjs",
    "generate:assets": "node scripts/generate-logo-assets.mjs"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "dependencies": {
    "node-pg-migrate": "8.0.4"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.10",
    "@commitlint/cli": "20.2.0",
    "@commitlint/config-conventional": "20.2.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/exec": "7.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/pg": "8.16.0",
    "conventional-changelog-conventionalcommits": "8.0.0",
    "danger": "12.3.3",
    "pg": "8.16.3",
    "semantic-release": "24.2.5",
    "sharp": "0.34.5",
    "typescript": "5.9.3"
  }
}

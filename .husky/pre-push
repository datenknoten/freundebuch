#!/usr/bin/env sh

# Pre-push hook: Run the same checks as CI
# This ensures local validation matches CI pipeline exactly

echo "🔍 Running pre-push checks (same as CI)..."

echo ""
echo "📋 Step 1/6: Danger local checks..."
npx danger local --base main || exit 1

echo ""
echo "📋 Step 2/6: Biome check (lint + format)..."
pnpm run check || exit 1

echo ""
echo "📋 Step 3/6: TypeScript type check..."
pnpm run type-check || exit 1

echo ""
echo "📋 Step 4/6: Running TypeScript tests..."
pnpm --recursive run test || exit 1

echo ""
echo "📋 Step 5/6: Running PHP tests..."
# Ensure PHP dependencies are installed
if [ ! -d "apps/sabredav/vendor" ]; then
    echo "⚠️  PHP dependencies not installed. Installing..."
    (cd apps/sabredav && composer install --no-interaction --prefer-dist --quiet) || exit 1
fi
pnpm run test:php || exit 1

echo ""
echo "📋 Step 6/6: Build verification..."
pnpm run build || exit 1

echo ""
echo "✅ All pre-push checks passed!"
